tags: $:/tags/Static/CSS
title: $:/_UseFonts

\rules only filteredtranscludeinline transcludeinline macrodef macrocallinline

html {
	font-family: 'Open Sans', 'Helvetica Neue', Helvetica, Arial, 'Lucida Grande', 'DejaVu Sans', sans-serif;
