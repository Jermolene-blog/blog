{
	"description": "Jermolene.com",
	"plugins": [
	],
	"themes": [
		"tiddlywiki/vanilla",
		"tiddlywiki/snowwhite"
	],
	"languages": [
	],
	"build": {
		"static": [
			"--save",
				"[!is[system]is[image]] [all[tiddlers+shadows]tag[$:/tags/Static/Attachment/Raw]] [[$:/favicon.ico]]",
				"[slugify[]]",
			"--render",
				"[all[tiddlers+shadows]tag[$:/tags/Static/Attachment/Rendered]]",
				"[slugify[]]",
				"text/plain",
			"--setfield",
				"[!is[system]is[image]]",
				"_canonical_uri",
				"$:/plugins/tiddlywiki/static/canonical-uri-external-slugified",
				"text/plain",
			"--setfield",
				"[!is[system]is[image]]",
				"text",
				"",
				"text/plain",
			"--render",
				"[tag[post]] [tag[page]]",
				"[slugify[]addsuffix[/index.html]]",
				"text/plain",
				"$:/plugins/tiddlywiki/static/templates/pages/single-tiddler",
			"--render",
				"[[$:/plugins/tiddlywiki/static/templates/pages/tiddler-river]]",
				"[[index.html]]",
				"text/plain",
			"--render",
				"[[$:/core/save/all]]",
				"[[wiki/index.html]]",
				"text/plain"
		]
	}
}
